{
  "name": "composio-x-pi",
  "version": "0.0.12",
  "description": "Pi extension that exposes Composio-backed runtime and authoring tools.",
  "keywords": [
    "pi-package",
    "pi-extension",
    "composio"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tridha643/composio-x-pi.git"
  },
  "bugs": {
    "url": "https://github.com/tridha643/composio-x-pi/issues"
  },
  "homepage": "https://github.com/tridha643/composio-x-pi#readme",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "build": "bun build src/index.ts --target bun --format esm --outdir dist",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:e2e": "bun run tests/e2e-extension.ts",
    "test:e2e:signup": "bun run tests/e2e-real-signup.ts",
    "test:integration": "bun run tests/integration.ts",
    "dev:pi": "bun run examples/embed-authoring.ts"
  },
  "dependencies": {
    "@composio/core": "*",
    "@sinclair/typebox": "^0.34.41"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "bun-types": "^1.3.9",
    "typescript": "^5.8.3"
  }
}
